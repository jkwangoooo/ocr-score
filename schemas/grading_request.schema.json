{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "essay-grading/schemas/grading_request.schema.json",
  "title": "EssayGradingRequest",
  "type": "object",
  "required": ["rubric_id", "essay_text"],
  "properties": {
    "rubric_id": {
      "type": "string",
      "minLength": 1
    },
    "essay_text": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "properties": {
        "source": {"type": "string"},
        "text_quality": {
          "type": "string",
          "enum": ["normal", "noisy", "short", "broken"]
        },
        "student_name": {"type": "string"},
        "student_no": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
